rule classifier_heatmaps:
    input:
        X_train=X_TRAIN,
        X_test=X_TEST,
        cv_results=f"{OUTPUT_FOLDER}/test_set_cv_results.csv",
        # Depend on all individual evaluation results to trigger parallelization
        # Regular adjustment methods (with METHOD_ prefix)
        method_result_files=expand(
            f"{OUTPUT_FOLDER}/classifier_results/{{classifier}}/METHOD_{{adjuster}}__{{label}}.json",
            classifier="{classifier}",
            adjuster=list(config["adjusters"].keys()),
            label=METADATA_LABELS
        ),
        # ORACLE multi-label DBA evaluation results (with ORACLE_ prefix)
        oracle_shift_only_results=expand(
            f"{OUTPUT_FOLDER}/classifier_results/{{classifier}}/ORACLE_multi_label_dba_shift_only__{{label}}.json",
            classifier="{classifier}",
            label=METADATA_LABELS
        ),
        oracle_shift_scale_results=expand(
            f"{OUTPUT_FOLDER}/classifier_results/{{classifier}}/ORACLE_multi_label_dba_shift_scale__{{label}}.json",
            classifier="{classifier}",
            label=METADATA_LABELS
        ),
        # DBA comparison outputs (these will trigger training and evaluation)
        dba_comparison_shift_only=f"{OUTPUT_FOLDER}/dba_classifier_comparison_shift_only/classifier_comparison.csv",
        dba_comparison_shift_scale=f"{OUTPUT_FOLDER}/dba_classifier_comparison_shift_scale/classifier_comparison.csv",
    output:
        heatmap=f"{OUTPUT_FOLDER}/classifier_heatmaps/heatmap_{{classifier}}.png",
        csv=f"{OUTPUT_FOLDER}/classifier_heatmaps/results_{{classifier}}.csv",
    params:
        classifier_name=lambda wildcards: CLASSIFIER_NAMES[wildcards.classifier],
        results_dir=f"{OUTPUT_FOLDER}/classifier_results/{{classifier}}",
        output_dir=f"{OUTPUT_FOLDER}/classifier_heatmaps"
    resources:
        mem_mb=4000,
        runtime=20
    threads: 1
    log:
        "logs/classifier_heatmaps_{classifier}.log"
    shell:
        """
        python scripts/aggregate_and_plot_heatmap.py \
            --results-dir {params.results_dir} \
            --classifier '{params.classifier_name}' \
            --cv-results {input.cv_results} \
            --output-heatmap {output.heatmap} \
            --output-csv {output.csv} \
            &> {log}
        """


