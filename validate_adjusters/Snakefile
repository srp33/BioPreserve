rule oracle_shift_scale:
    input:
        train_genes="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_genes_unadjusted="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_genes_bayesian="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        train_metadata=X_TRAIN,
        test_metadata=X_TEST
    output:
        comparison=f"{OUTPUT_FOLDER}/oracle_analysis/adjustment_comparison.png",
        parameters=f"{OUTPUT_FOLDER}/oracle_analysis/oracle_parameters.png",
        params_csv=f"{OUTPUT_FOLDER}/oracle_analysis/oracle_parameters.csv",
        adjusted_data=f"{OUTPUT_FOLDER}/oracle_analysis/test_genes_oracle_adjusted.csv"
    params:
        target_genes="ERBB2 STARD3 PGAP3",
        output_dir=f"{OUTPUT_FOLDER}/oracle_analysis"
    resources:
        mem_mb=4000,
        runtime=180
    threads: 1
    log:
        "logs/oracle_shift_scale.log"
    shell:
        """
        python scripts/oracle_shift_scale.py \
            --train-genes {input.train_genes} \
            --test-genes-unadjusted {input.test_genes_unadjusted} \
            --test-genes-bayesian {input.test_genes_bayesian} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --target-genes {params.target_genes} \
            --output-dir {params.output_dir} \
            &> {log}
        """


