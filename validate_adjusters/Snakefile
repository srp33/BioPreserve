from pathlib import Path
import os
import shlex

# Get the directory where this Snakefile is located
BASE = Path(workflow.basedir)
configfile: str(BASE / "config" / "config.yaml")

OUTPUT_FOLDER = config["output_folder"]
X_TRAIN = os.path.join(BASE, config["X_train"])
X_TEST = os.path.join(BASE, config["X_test"])


# Get metadata labels from config
METADATA_LABELS = [
    'meta_er_status',
    'meta_menopause_status', 
    'meta_sex',
    'meta_age_at_diagnosis',
    'meta_chemotherapy',
    'meta_histological_type',
    'meta_her2_status',
    'meta_age_at_diagnosis_combined_lt50',
    'meta_age_at_diagnosis_combined_50_69',
    'meta_age_at_diagnosis_combined_ge70'
]
# Define classifiers for parallel execution
CLASSIFIERS = ['Random_Forest', 'Gradient_Boosting', 'Logistic_L2', 'ElasticNet_l1_0.15']
CLASSIFIER_NAMES = {
    'Random_Forest': 'Random Forest',
    'Gradient_Boosting': 'Gradient Boosting',
    'Logistic_L2': 'Logistic (L2)',
    'ElasticNet_l1_0.15': 'ElasticNet (l1=0.15)'
}

# DBA training classifiers (used for oracle adjustment methods)
DBA_CLASSIFIERS = ['histgradient', 'elasticnet', 'logistic', 'randomforest']

# Rule order: specific multi-label DBA rules should be preferred over generic evaluate_adjuster_label
ruleorder: evaluate_multi_label_dba > evaluate_adjuster_label
ruleorder: evaluate_dba_trained > evaluate_adjuster_label

rule all:
    input:
        f"{OUTPUT_FOLDER}/heatmap.png",
        f"{OUTPUT_FOLDER}/test_set_cv_results.csv",
        f"{OUTPUT_FOLDER}/gene_analysis/her2_status_heatmap.png",
        f"{OUTPUT_FOLDER}/gene_analysis/chemotherapy_informativeness.png",
        f"{OUTPUT_FOLDER}/oracle_analysis/adjustment_comparison.png",
        f"{OUTPUT_FOLDER}/debug_analysis/parameter_comparison.png",
        expand(f"{OUTPUT_FOLDER}/classifier_heatmaps/heatmap_{{classifier}}.png", classifier=CLASSIFIERS),
        f"{OUTPUT_FOLDER}/optimal_strategy.png",
        f"{OUTPUT_FOLDER}/dba_analysis/dba_comparison.png",
        f"{OUTPUT_FOLDER}/multi_label_dba_shift_only/multi_label_comparison.csv",
        f"{OUTPUT_FOLDER}/multi_label_dba_shift_scale/multi_label_comparison.csv",
        f"{OUTPUT_FOLDER}/dba_classifier_comparison_shift_only/classifier_comparison.csv",
        f"{OUTPUT_FOLDER}/dba_classifier_comparison_shift_scale/classifier_comparison.csv",
        "adjusters/effective_shifts.csv",
        f"{OUTPUT_FOLDER}/feature_selection_comparison.csv",
        # Explicitly request DBA evaluation files to ensure they're generated
        expand(
            f"{OUTPUT_FOLDER}/classifier_results/{{eval_classifier}}/DBA_Shift_Only_Trained_{{training_classifier}}__{{label}}.json",
            eval_classifier=CLASSIFIERS,
            training_classifier=DBA_CLASSIFIERS,
            label=METADATA_LABELS
        ),
        expand(
            f"{OUTPUT_FOLDER}/classifier_results/{{eval_classifier}}/DBA_Shift_Scale_Trained_{{training_classifier}}__{{label}}.json",
            eval_classifier=CLASSIFIERS,
            training_classifier=DBA_CLASSIFIERS,
            label=METADATA_LABELS
        ),


rule test_set_cv:
    input:
        test_genes="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_metadata=X_TEST
    output:
        results=f"{OUTPUT_FOLDER}/test_set_cv_results.csv"
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        n_splits=config.get("cv_n_splits", 5)
    resources:
        mem_mb=4000,
        runtime=60
    threads: 1
    log:
        "logs/test_set_cv.log"
    shell:
        """
        python scripts/test_set_cv.py \
            --genes {input.test_genes} \
            --metadata {input.test_metadata} \
            --continuous-metadata {params.continuous_metadata} \
            --n-splits {params.n_splits} \
            --output {output.results} \
            &> {log}
        """


rule create_effective_shift_only:
    input:
        unadjusted="../bayesian_shift_scale_adjuster/outputs/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        bayesian_adjusted="../bayesian_shift_scale_adjuster/outputs/adjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        train_source="../bayesian_shift_scale_adjuster/outputs/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv"
    output:
        test="adjusters/adjusted_bayesian_effective_shift_only_2studies_test_metabric_test_selected_genes.csv",
        train="adjusters/adjusted_bayesian_effective_shift_only_2studies_test_metabric_train_selected_genes.csv",
        shifts="adjusters/effective_shifts.csv"
    resources:
        mem_mb=2000,
        runtime=10
    threads: 1
    log:
        "logs/create_effective_shift_only.log"
    shell:
        """
        python scripts/create_effective_shift_only.py \
            --unadjusted {input.unadjusted} \
            --bayesian-adjusted {input.bayesian_adjusted} \
            --output-test {output.test} \
            --output-train {output.train} \
            --train-source {input.train_source} \
            --output-shifts {output.shifts} \
            &> {log}
        """


rule feature_selection_comparison:
    input:
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
        train_unadjusted="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_unadjusted="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        train_shift_scale="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_shift_scale="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        train_shift_only="adjusters/adjusted_bayesian_effective_shift_only_2studies_test_metabric_train_selected_genes.csv",
        test_shift_only="adjusters/adjusted_bayesian_effective_shift_only_2studies_test_metabric_test_selected_genes.csv",
    output:
        results=f"{OUTPUT_FOLDER}/feature_selection_comparison.csv"
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        n_genes="3 5 10 20 50"
    resources:
        mem_mb=8000,
        runtime=120
    threads: 1
    log:
        "logs/feature_selection_comparison.log"
    shell:
        """
        python scripts/feature_selection_comparison.py \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --train-unadjusted {input.train_unadjusted} \
            --test-unadjusted {input.test_unadjusted} \
            --train-shift-scale {input.train_shift_scale} \
            --test-shift-scale {input.test_shift_scale} \
            --train-shift-only {input.train_shift_only} \
            --test-shift-only {input.test_shift_only} \
            --continuous-metadata {params.continuous_metadata} \
            --n-genes {params.n_genes} \
            --output {output.results} \
            &> {log}
        """


rule cross_dataset_classify:
    input:
        X_train=X_TRAIN,
        X_test=X_TEST,
        adjuster_files=[
            os.path.join(BASE, path)
            for adj in config["adjusters"].values()
            for path in [adj["train"], adj["test"]]
        ],
        # Ensure effective shift only is created first
        effective_shifts="adjusters/effective_shifts.csv",
        # Ensure multi-label DBA outputs are created (absolute paths)
        multi_label_dba_shift_only=os.path.join(BASE, f"{OUTPUT_FOLDER}/multi_label_dba_shift_only/test_genes_multi_label_dba_direct.csv"),
        multi_label_dba_shift_scale=os.path.join(BASE, f"{OUTPUT_FOLDER}/multi_label_dba_shift_scale/test_genes_multi_label_dba_direct.csv"),
    output:
        results=f"{OUTPUT_FOLDER}/classification_results.csv",
    params:
        adjusters_static=" ".join(
            shlex.quote(f"{k}={os.path.join(BASE, v['train'])}:{os.path.join(BASE, v['test'])}")
            for k, v in config["adjusters"].items()
        ),
        # Add multi-label DBA adjusters with absolute paths
        adjusters_dba=lambda wildcards, input: " ".join([
            shlex.quote(f"multi_label_dba_shift_only={os.path.join(BASE, 'adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv')}:{input.multi_label_dba_shift_only}"),
            shlex.quote(f"multi_label_dba_shift_scale={os.path.join(BASE, 'adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv')}:{input.multi_label_dba_shift_scale}"),
        ]),
        continuous_metadata=" ".join(config["continuous_metadata"]),
    resources:
        mem_mb=8000,
        runtime=120
    threads: 1
    log:
        "logs/cross_dataset_classify.log"
    shell:
        """
        python scripts/cross_dataset_classify.py \
            --X-train "{input.X_train}" \
            --X-test "{input.X_test}" \
            --adjusters {params.adjusters_static} {params.adjusters_dba} \
            --continuous-metadata {params.continuous_metadata} \
            --output "{output.results}" \
            &> "{log}"
        """


