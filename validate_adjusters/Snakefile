# Individual evaluation jobs - one per (classifier, adjuster, label) combination
# These are the regular adjustment methods (not oracle)
rule evaluate_adjuster_label:
    input:
        train_genes=lambda wildcards: os.path.join(BASE, config["adjusters"][wildcards.adjuster]["train"]),
        test_genes=lambda wildcards: os.path.join(BASE, config["adjusters"][wildcards.adjuster]["test"]),
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
    output:
        result=f"{OUTPUT_FOLDER}/classifier_results/{{classifier}}/METHOD_{{adjuster}}__{{label}}.json",
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        classifier_name=lambda wildcards: CLASSIFIER_NAMES[wildcards.classifier],
    resources:
        mem_mb=2000,
        runtime=10
    threads: 1
    log:
        "logs/evaluate_{classifier}_METHOD_{adjuster}_{label}.log"
    shell:
        """
        python scripts/evaluate_single_adjuster_label.py \
            --train-genes {input.train_genes} \
            --test-genes {input.test_genes} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --adjuster-name {wildcards.adjuster} \
            --label {wildcards.label} \
            --classifier '{params.classifier_name}' \
            --continuous-metadata {params.continuous_metadata} \
            --output {output.result} \
            &> {log}
        """


# Evaluation for multi-label DBA (Oracle method, unified for both shift types)
rule evaluate_multi_label_dba:
    input:
        train_genes=os.path.join(BASE, "adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv"),
        test_genes=lambda wildcards: os.path.join(BASE, f"{OUTPUT_FOLDER}/multi_label_dba_{wildcards.shift_type}/test_genes_multi_label_dba_direct.csv"),
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
    output:
        result=f"{OUTPUT_FOLDER}/classifier_results/{{classifier}}/ORACLE_multi_label_dba_{{shift_type}}__{{label}}.json",
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        classifier_name=lambda wildcards: CLASSIFIER_NAMES[wildcards.classifier],
        adjuster_name=lambda wildcards: f"ORACLE: Multi-Label DBA ({wildcards.shift_type.replace('_', '-').title()})",
    resources:
        mem_mb=2000,
        runtime=10
    threads: 1
    log:
        "logs/evaluate_{classifier}_ORACLE_multi_label_dba_{shift_type}_{label}.log"
    wildcard_constraints:
        shift_type="shift_only|shift_scale"
    shell:
        """
        python scripts/evaluate_single_adjuster_label.py \
            --train-genes {input.train_genes} \
            --test-genes {input.test_genes} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --adjuster-name "{params.adjuster_name}" \
            --label {wildcards.label} \
            --classifier '{params.classifier_name}' \
            --continuous-metadata {params.continuous_metadata} \
            --output {output.result} \
            &> {log}
        """


# Evaluation for DBA trained with specific classifiers (unified for both shift types)
rule evaluate_dba_trained:
    input:
        train_genes=os.path.join(BASE, "adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv"),
        test_genes=lambda wildcards: f"{OUTPUT_FOLDER}/dba_classifier_comparison_{'shift_only' if wildcards.shift_label == 'Shift_Only' else 'shift_scale'}/test_genes_dba_{wildcards.training_classifier}.csv",
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
    output:
        result=f"{OUTPUT_FOLDER}/classifier_results/{{eval_classifier}}/DBA_{{shift_label}}_Trained_{{training_classifier}}__{{label}}.json",
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        classifier_name=lambda wildcards: CLASSIFIER_NAMES[wildcards.eval_classifier],
        adjuster_name=lambda wildcards: f"DBA: {wildcards.training_classifier.title()} ({wildcards.shift_label.replace('_', '+')})",
    resources:
        mem_mb=2000,
        runtime=10
    threads: 1
    log:
        "logs/evaluate_{eval_classifier}_DBA_{shift_label}_Trained_{training_classifier}_{label}.log"
    wildcard_constraints:
        shift_label="Shift_Only|Shift_Scale"
    shell:
        """
        python scripts/evaluate_single_adjuster_label.py \
            --train-genes {input.train_genes} \
            --test-genes {input.test_genes} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --adjuster-name "{params.adjuster_name}" \
            --label {wildcards.label} \
            --classifier '{params.classifier_name}' \
            --continuous-metadata {params.continuous_metadata} \
            --output {output.result} \
            &> {log}
        """




rule decision_boundary_alignment:
    input:
        train_genes="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_genes_unadjusted="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_genes_bayesian="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_genes_effective="adjusters/adjusted_bayesian_effective_shift_only_2studies_test_metabric_test_selected_genes.csv",
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
        effective_shifts="adjusters/effective_shifts.csv",
    output:
        comparison=f"{OUTPUT_FOLDER}/dba_analysis/dba_comparison.png",
        results=f"{OUTPUT_FOLDER}/dba_analysis/dba_results.csv",
        parameters=f"{OUTPUT_FOLDER}/dba_analysis/dba_parameters.csv",
        adjusted_direct=f"{OUTPUT_FOLDER}/dba_analysis/test_genes_dba_direct.csv",
        adjusted_coef=f"{OUTPUT_FOLDER}/dba_analysis/test_genes_dba_coefficient.csv",
        adjusted_hybrid=f"{OUTPUT_FOLDER}/dba_analysis/test_genes_dba_hybrid.csv"
    params:
        target_label="meta_her2_status",
        n_top_genes=10,
        classifier="elasticnet",
        output_dir=f"{OUTPUT_FOLDER}/dba_analysis"
    log:
        "logs/decision_boundary_alignment.log"
    shell:
        """
        python scripts/decision_boundary_alignment.py \
            --train-genes {input.train_genes} \
            --test-genes-unadjusted {input.test_genes_unadjusted} \
            --test-genes-bayesian {input.test_genes_bayesian} \
            --test-genes-effective {input.test_genes_effective} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --target-label {params.target_label} \
            --n-top-genes {params.n_top_genes} \
            --classifier {params.classifier} \
            --output-dir {params.output_dir} \
            &> {log}
        """


# Multi-label DBA analysis (unified for both shift types)
rule multi_label_dba_analysis:
    input:
        train_genes="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_genes_unadjusted="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_genes_bayesian="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_genes_effective="adjusters/adjusted_bayesian_effective_shift_only_2studies_test_metabric_test_selected_genes.csv",
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
        effective_shifts="adjusters/effective_shifts.csv",
    output:
        comparison=f"{OUTPUT_FOLDER}/multi_label_dba_{{shift_type}}/multi_label_comparison.csv",
        parameters=f"{OUTPUT_FOLDER}/multi_label_dba_{{shift_type}}/multi_label_dba_parameters.csv",
        adjusted_cf=f"{OUTPUT_FOLDER}/multi_label_dba_{{shift_type}}/test_genes_multi_label_dba_closed_form.csv",
        adjusted_direct=f"{OUTPUT_FOLDER}/multi_label_dba_{{shift_type}}/test_genes_multi_label_dba_direct.csv"
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        output_dir=f"{OUTPUT_FOLDER}/multi_label_dba_{{shift_type}}",
        shift_only_flag=lambda wildcards: "--shift-only" if wildcards.shift_type == "shift_only" else ""
    resources:
        mem_mb=8000,
        runtime=180
    threads: 1
    log:
        "logs/multi_label_dba_{shift_type}.log"
    wildcard_constraints:
        shift_type="shift_only|shift_scale"
    shell:
        """
        python scripts/multi_label_dba.py \
            --train-genes {input.train_genes} \
            --test-genes-unadjusted {input.test_genes_unadjusted} \
            --test-genes-bayesian {input.test_genes_bayesian} \
            --test-genes-effective {input.test_genes_effective} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --continuous-metadata {params.continuous_metadata} \
            {params.shift_only_flag} \
            --output-dir {params.output_dir} \
            &> {log}
        """


# DBA Classifier Comparison Analysis
# Train DBA with different classifiers and evaluate across all classifiers
# Parallelized: each classifier trains in its own job

# Individual training rules for each classifier (unified for both shift types)
rule dba_train_classifier:
    input:
        train_genes="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_genes_unadjusted="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        test_genes_bayesian="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
    output:
        adjusted=f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}/test_genes_dba_{{classifier}}.csv",
        parameters=f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}/dba_parameters_{{classifier}}.csv",
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        output_dir=f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}",
        shift_only_flag=lambda wildcards: "--shift-only" if wildcards.shift_type == "shift_only" else ""
    resources:
        mem_mb=8000,
        runtime=lambda wildcards: 120 if wildcards.shift_type == "shift_only" else 180
    threads: 1
    log:
        "logs/dba_train_{classifier}_{shift_type}.log"
    shell:
        """
        python scripts/multi_label_dba.py \
            --train-genes {input.train_genes} \
            --test-genes-unadjusted {input.test_genes_unadjusted} \
            --test-genes-bayesian {input.test_genes_bayesian} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --continuous-metadata {params.continuous_metadata} \
            --training-classifier {wildcards.classifier} \
            {params.shift_only_flag} \
            --output-dir {params.output_dir} \
            &> {log}
        """


# Aggregate and evaluate all trained models (unified for both shift types)
rule dba_classifier_comparison:
    input:
        train_genes="adjusters/adjusted_bayesian_shift_scale_2studies_test_metabric_train_selected_genes.csv",
        test_genes_unadjusted="adjusters/unadjusted_bayesian_shift_scale_2studies_test_metabric_test_selected_genes.csv",
        train_metadata=X_TRAIN,
        test_metadata=X_TEST,
        # Depend on individual training outputs
        adjusted_files=lambda wildcards: expand(
            f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}/test_genes_dba_{{classifier}}.csv",
            shift_type=wildcards.shift_type,
            classifier=DBA_CLASSIFIERS
        ),
        param_files=lambda wildcards: expand(
            f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}/dba_parameters_{{classifier}}.csv",
            shift_type=wildcards.shift_type,
            classifier=DBA_CLASSIFIERS
        ),
        # Depend on all evaluation results
        evaluation_results=lambda wildcards: expand(
            f"{OUTPUT_FOLDER}/classifier_results/{{eval_classifier}}/DBA_{{shift_label}}_Trained_{{training_classifier}}__{{label}}.json",
            eval_classifier=CLASSIFIERS,
            shift_label="Shift_Only" if wildcards.shift_type == "shift_only" else "Shift_Scale",
            training_classifier=DBA_CLASSIFIERS,
            label=METADATA_LABELS
        ),
    output:
        comparison=f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}/classifier_comparison.csv",
    params:
        continuous_metadata=" ".join(config["continuous_metadata"]),
        training_classifiers=" ".join(DBA_CLASSIFIERS),
        evaluation_classifiers=" ".join(DBA_CLASSIFIERS),
        output_dir=f"{OUTPUT_FOLDER}/dba_classifier_comparison_{{shift_type}}",
        shift_only_flag=lambda wildcards: "--shift-only" if wildcards.shift_type == "shift_only" else ""
    resources:
        mem_mb=2000,
        runtime=10
    threads: 1
    log:
        "logs/dba_classifier_comparison_{shift_type}.log"
    shell:
        """
        python scripts/dba_classifier_comparison.py \
            --train-genes {input.train_genes} \
            --test-genes-unadjusted {input.test_genes_unadjusted} \
            --train-metadata {input.train_metadata} \
            --test-metadata {input.test_metadata} \
            --continuous-metadata {params.continuous_metadata} \
            --training-classifiers {params.training_classifiers} \
            --evaluation-classifiers {params.evaluation_classifiers} \
            {params.shift_only_flag} \
            --aggregate-only \
            --output-dir {params.output_dir} \
            &> {log}
        """
